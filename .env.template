# Azure AI Foundry / Azure OpenAI endpoint settings
# Copy this file to .env and fill in your values
# Authentication: run `az login` before starting the agent — no API key required

# The Azure OpenAI endpoint URL from your Foundry project
# Found in: AI Foundry portal → your project → Overview → Azure OpenAI endpoint
AZURE_API_BASE=https://<resource>.openai.azure.com/

# The API version to use
AZURE_API_VERSION=2024-12-01-preview

# The name of your model deployment in Azure AI Foundry
AZURE_DEPLOYMENT_NAME=gpt-4o
